{
  "name": "dockervis",
  "version": "1.0.0",
  "description": "Modern TypeScript terminal dashboard for Docker containers - lightweight alternative to ctop",
  "main": "dist/index.js",
  "bin": {
    "dockervis": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src tests --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run lint && npm run build && npm test"
  },
  "keywords": [
    "docker",
    "terminal",
    "dashboard",
    "monitoring",
    "containers",
    "cli",
    "typescript",
    "tui",
    "ctop",
    "lazydocker"
  ],
  "author": "Sulthonzh",
  "license": "MIT",
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "blessed": "^0.1.81",
    "chalk": "^4.1.2",
    "cli-spinner": "^0.2.10",
    "dockerode": "^3.3.5",
    "inquirer": "^9.2.12",
    "typescript-eslint": "^8.60.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.21",
    "@types/dockerode": "^4.0.1",
    "@types/inquirer": "^9.0.3",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.6.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sulthonzh/dockervis.git"
  },
  "bugs": {
    "url": "https://github.com/sulthonzh/dockervis/issues"
  },
  "homepage": "https://github.com/sulthonzh/dockervis#readme"
}
