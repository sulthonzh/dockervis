{
  "name": "dockervis",
  "version": "1.0.0",
  "description": "A modern TypeScript terminal dashboard for Docker containers with real-time monitoring",
  "type": "module",
  "bin": {
    "dockervis": "./dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "docker",
    "containers",
    "monitoring",
    "terminal",
    "dashboard",
    "cli",
    "tui",
    "docker-api",
    "devops",
    "developer-tools"
  ],
  "author": "Sulthon",
  "license": "MIT",
  "dependencies": {
    "blessed": "^0.1.81",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dockerode": "^4.0.2",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.21",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^20.12.12",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sulthonzh/dockervis"
  },
  "bugs": {
    "url": "https://github.com/sulthonzh/dockervis/issues"
  },
  "homepage": "https://github.com/sulthonzh/dockervis#readme"
}
